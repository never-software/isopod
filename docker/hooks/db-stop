#!/bin/bash
# hooks/db-stop — Stop the database before a snapshot
#
# Called by: isopod db save, isopod db restore
# Env: CONTAINER — the Docker container name
#
# Implement this for your database. The database must be stopped cleanly
# before a volume snapshot to ensure data consistency.
#
# Examples:
#   PostgreSQL:  docker exec "$CONTAINER" su postgres -c "pg_ctl stop -D /pgdata -m fast"
#   MySQL:       docker exec "$CONTAINER" mysqladmin shutdown
#   MongoDB:     docker exec "$CONTAINER" mongosh --eval "db.adminCommand({shutdown: 1})"

set -euo pipefail

echo "⚠ db-stop hook not configured — implement this for your database"
